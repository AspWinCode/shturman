AUTH_API_PORT=8787
AUTH_API_HOST=0.0.0.0
AUTH_JWT_SECRET=replace-with-strong-secret-at-least-32-chars
AUTH_ENABLE_DEMO_USER=true
AUTH_ENABLE_TRIPS_RESET=true
AUTH_ENABLE_TRIPS_RESEED=true
DATABASE_URL=
PG_SSL=false

EXPO_PUBLIC_AUTH_API_URL=http://localhost:8787
EXPO_PUBLIC_SHOW_DEMO_CREDENTIALS=true
EXPO_PUBLIC_ENABLE_DEMO_RESET=true

# Aviasales / Travelpayouts API token
# Получить на https://travelpayouts.com
EXPO_PUBLIC_AVIASALES_TOKEN=your_token_here
