{
  "name": "shturman-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "dev:api": "node api/server.js",
    "smoke:api": "node scripts/smoke-api.mjs",
    "smoke:content": "node scripts/smoke-content.mjs",
    "smoke:encoding": "node scripts/smoke-encoding.mjs",
    "preflight:mobile": "node scripts/preflight-mobile.mjs",
    "poi:import:osm": "node scripts/import-poi-osm.mjs",
    "seed:api-json": "node scripts/seed-api-json-db.mjs",
    "db:up": "docker compose -f api/docker-compose.postgres.yml up -d",
    "db:down": "docker compose -f api/docker-compose.postgres.yml down",
    "build:web": "expo export --platform web && node scripts/patch-dist.js",
    "patch": "node scripts/patch-dist.js"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.2.3",
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.3.1",
    "expo": "~51.0.0",
    "expo-blur": "~13.0.0",
    "expo-constants": "~16.0.2",
    "expo-document-picker": "~12.0.2",
    "expo-file-system": "~17.0.1",
    "expo-font": "~12.0.0",
    "expo-haptics": "~13.0.0",
    "expo-linear-gradient": "~13.0.0",
    "expo-linking": "~6.3.1",
    "expo-notifications": "~0.28.19",
    "expo-router": "~3.5.0",
    "expo-sharing": "~12.0.1",
    "expo-splash-screen": "~0.27.0",
    "expo-sqlite": "~14.0.6",
    "expo-status-bar": "~1.12.0",
    "pg": "^8.20.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-iap": "^15.2.0",
    "react-native-maps": "1.14.0",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-web": "~0.19.10",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.45",
    "glob": "^13.0.6",
    "typescript": "~5.3.0"
  }
}
